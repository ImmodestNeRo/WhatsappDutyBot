# ── DutyBot Configuration ──────────────────────────────────
# Copy this file to `.env` and adjust values as needed.
# All values shown below are the defaults.

# Path to the data directory (session.db, JSON files, logs)
DATA_DIR=./data

# WhatsApp group JID to auto-bind to (e.g. 120363012345678901@g.us)
# Leave empty to use /bind_group command manually.
GROUP_JID=

# Timezone for scheduler
TIMEZONE=Europe/Kyiv

# Schedule times in HH:MM format
SCHEDULE_MORNING=08:00
SCHEDULE_REMINDER_1=14:00
SCHEDULE_REMINDER_2=17:30

# Phone number that must always remain last in the queue (optional)
QUEUE_ALWAYS_LAST=

# Comma-separated list of admin phone numbers (without +)
ADMIN_PHONES=

# Rate limiting: max commands per user per window (seconds)
RATE_LIMIT_CALLS=5
RATE_LIMIT_WINDOW=60

# How many seconds to ignore messages after boot (history sync filter)
HISTORY_SYNC_GRACE=60

# Logging
LOG_LEVEL=INFO
LOG_MAX_BYTES=10485760
LOG_BACKUP_COUNT=5
